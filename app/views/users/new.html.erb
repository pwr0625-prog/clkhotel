<main class="listings-main">
  <div class="listings-header"><h1>회원가입</h1></div>
  <section class="hotel-search-box">
    <%= form_with model: @user, url: signup_path, local: true do |form| %>
      <% if @user.errors.any? %>
        <div class="flash flash--alert" style="margin:0 0 12px 0;">
          <%= @user.errors.full_messages.to_sentence %>
        </div>
      <% end %>

      <div class="hotel-search-form" style="grid-template-columns: repeat(2, minmax(180px, 1fr));">
        <div class="field-group"><%= form.label :name, "이름" %><%= form.text_field :name, required: true, class: "field-input" %></div>
        <div class="field-group"><%= form.label :phone, "전화번호" %><%= form.text_field :phone, class: "field-input" %></div>
        <div class="field-group"><%= form.label :email, "이메일" %><%= form.email_field :email, required: true, class: "field-input" %></div>
        <div class="field-group"><%= form.label :user_type, "회원 유형" %><%= form.select :user_type, [["게스트", "guest"], ["호스트", "host"]], {}, class: "field-input" %></div>
        <div class="field-group"><%= form.label :password, "비밀번호" %><%= form.password_field :password, required: true, class: "field-input" %></div>
        <div class="field-group"><%= form.label :password_confirmation, "비밀번호 확인" %><%= form.password_field :password_confirmation, required: true, class: "field-input" %></div>
      </div>

      <%= form.submit "가입하기", class: "search-button", style: "margin-top:12px;" %>
    <% end %>
  </section>
</main>
