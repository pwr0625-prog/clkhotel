<main class="listings-main">
  <div class="listings-header">
    <h1>예약 확정 (호수 지정)</h1>
    <%= link_to "호스트 예약 관리", host_bookings_path %>
  </div>

  <section class="post-list-box">
    <div class="post-list-header">
      <h2><%= @booking.booking_code %></h2>
      <span><%= @booking.status_label %></span>
    </div>
    <p><strong>숙소</strong>: <%= @booking.property.property_name %></p>
    <p><strong>객실유형</strong>: <%= @booking.room_type.room_name %></p>
    <p><strong>일정</strong>: <%= @booking.check_in_date %> ~ <%= @booking.check_out_date %> (<%= @booking.nights %>박)</p>
    <p><strong>예약 객실 수</strong>: <%= @booking.room_count %>실</p>
    <p><strong>게스트</strong>: <%= @booking.user.name %> (<%= @booking.user.phone.presence || "전화번호 없음" %>)</p>
  </section>

  <section class="post-list-box">
    <div class="post-list-header">
      <h2>호수 선택</h2>
      <span>선택 수는 <%= @booking.room_count %>실과 같아야 합니다.</span>
    </div>

    <% if @booking.room_type.room_numbers.blank? %>
      <p class="post-empty">이 객실유형에 등록된 호수 번호가 없습니다. 먼저 객실유형 수정 화면에서 호수 번호를 등록해 주세요.</p>
      <%= link_to "객실유형 수정으로 이동", edit_host_room_type_path(@booking.room_type), class: "new-listing-link" %>
    <% else %>
      <%= form_with url: host_confirm_booking_path(@booking), method: :patch, local: true do %>
        <div class="design-grid">
          <% @booking.room_type.room_numbers.each do |room_no| %>
            <% occupied = !@available_room_numbers.include?(room_no) %>
            <label class="design-card" style="opacity:<%= occupied ? 0.55 : 1 %>; cursor:<%= occupied ? 'not-allowed' : 'pointer' %>;">
              <div class="design-card__header">
                <h2 style="font-size:16px; margin:0;">호수 <%= room_no %></h2>
                <span><%= occupied ? "사용중" : "선택가능" %></span>
              </div>
              <div style="margin-top:10px;">
                <%= check_box_tag "booking[assigned_room_numbers][]",
                                  room_no,
                                  @booking.assigned_room_numbers.include?(room_no),
                                  disabled: occupied,
                                  style: "width:18px; height:18px;" %>
              </div>
            </label>
          <% end %>
        </div>
        <div style="margin-top:14px; display:flex; gap:10px; flex-wrap:wrap;">
          <%= submit_tag "호수 지정 후 예약 확정", class: "search-button" %>
          <%= link_to "뒤로", host_bookings_path, class: "nav-link" %>
        </div>
      <% end %>
    <% end %>
  </section>
</main>
