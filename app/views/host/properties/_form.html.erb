<%= form_with model: [:host, @property], local: true do |f| %>
  <% if @property.errors.any? %>
    <div class="flash flash--alert" style="margin:0 0 12px 0;"><%= @property.errors.full_messages.to_sentence %></div>
  <% end %>

  <div class="hotel-search-form" style="grid-template-columns: repeat(2, minmax(180px, 1fr));">
    <div class="field-group"><%= f.label :property_name, "숙소명" %><%= f.text_field :property_name, class: "field-input" %></div>
    <div class="field-group"><%= f.label :property_type, "숙소 유형" %><%= f.select :property_type, Property.property_types.keys, {}, class: "field-input" %></div>
    <div class="field-group"><%= f.label :is_open, "운영 상태" %><%= f.select :is_open, [["Open(운영중)", "true"], ["Close(준비중)", "false"]], {}, class: "field-input" %></div>
    <div class="field-group"><%= f.label :country, "국가" %><%= f.text_field :country, class: "field-input" %></div>
    <div class="field-group"><%= f.label :city, "도시" %><%= f.text_field :city, class: "field-input" %></div>
    <div class="field-group"><%= f.label :address, "주소" %><%= f.text_field :address, class: "field-input" %></div>
    <div class="field-group"><%= f.label :star_rating, "성급" %><%= f.number_field :star_rating, step: 0.5, min: 0, max: 5, class: "field-input" %></div>
    <div class="field-group"><%= f.label :check_in_time, "체크인 시간" %><%= f.time_field :check_in_time, class: "field-input" %></div>
    <div class="field-group"><%= f.label :check_out_time, "체크아웃 시간" %><%= f.time_field :check_out_time, class: "field-input" %></div>
  </div>
  <div class="field-group" style="margin-top:10px;"><%= f.label :description, "설명" %><%= f.text_area :description, rows: 4, class: "field-input", style: "height:auto; padding:10px;" %></div>
  <div style="margin-top:12px;"><%= f.submit class: "search-button" %></div>
<% end %>
